<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Melee Mods</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <a href="/" class="navbar-brand">
    MELEE
    <svg class="shine-o" width="24" height="24" viewBox="0 0 28 28" fill="none">
      <defs>
        <radialGradient id="sc" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#fff"/>
          <stop offset="30%" stop-color="#93c5fd"/>
          <stop offset="70%" stop-color="#3b82f6"/>
          <stop offset="100%" stop-color="#1d4ed8"/>
        </radialGradient>
        <radialGradient id="sg" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="14" cy="14" r="13" fill="url(#sg)"/>
      <polygon points="14,3 23,8 23,20 14,25 5,20 5,8" fill="url(#sc)" opacity="0.95"/>
      <line x1="14" y1="0"  x2="14" y2="4"  stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="14" y1="24" x2="14" y2="28" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="0"  y1="14" x2="4"  y2="14" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="24" y1="14" x2="28" y2="14" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="2"  y1="4"  x2="5"  y2="7"  stroke="#93c5fd" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
      <line x1="23" y1="21" x2="26" y2="24" stroke="#93c5fd" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
      <line x1="26" y1="4"  x2="23" y2="7"  stroke="#93c5fd" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
      <line x1="2"  y1="24" x2="5"  y2="21" stroke="#93c5fd" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
      <circle cx="14" cy="14" r="3.5" fill="white" opacity="0.92"/>
      <circle cx="12" cy="12" r="1.2" fill="white" opacity="0.6"/>
    </svg>
    <span>DS</span>
  </a>
  <ul class="navbar-nav">
    <li><a href="/mods?category=skins-personajes">Personajes</a></li>
    <li><a href="/mods?category=skins-escenarios">Escenarios</a></li>
    <li><a href="/mods?category=audio">Audio</a></li>
    <li><a href="/mods?category=hud">HUD</a></li>
  </ul>
  <div class="navbar-actions">
    <% if (user) { %>
      <a href="/mods/new" class="btn btn-primary btn-sm">+ Subir mod</a>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="btn btn-warning btn-sm">⚙ Admin</a>
      <% } %>
      <a href="/user/<%= user.username %>" class="btn btn-ghost btn-sm">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" style="width:20px;height:20px;border-radius:50%;object-fit:cover">
        <% } %>
        <%= user.username %>
      </a>
      <a href="/auth/logout" class="btn btn-ghost btn-sm">Salir</a>
    <% } else { %>
      <a href="/auth/login"    class="btn btn-ghost btn-sm">Iniciar sesión</a>
      <a href="/auth/register" class="btn btn-primary btn-sm">Registrarse</a>
    <% } %>
  </div>
</nav>
<% if (success_msg && success_msg.length > 0) { %>
  <div class="flash flash-success"><%= success_msg %></div>
<% } %>
<% if (error_msg && error_msg.length > 0) { %>
  <div class="flash flash-error"><%= error_msg %></div>
<% } %>
