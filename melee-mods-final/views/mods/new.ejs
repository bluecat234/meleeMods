<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h1>Subir mod</h1>
    <p>Comparte tu creación con la comunidad de Melee</p>
  </div>

  <form action="/mods" method="POST" enctype="multipart/form-data" style="max-width:680px">

    <div class="form-group">
      <label>Título *</label>
      <input type="text" name="title" required maxlength="255" placeholder="Ej: Fox HD Retexture">
    </div>

    <div class="form-group">
      <label>Categoría *</label>
      <select name="category_id" required>
        <option value="">Selecciona una categoría</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>"><%= cat.icon %> <%= cat.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label>Descripción</label>
      <textarea name="description" rows="4" placeholder="Describe tu mod..."></textarea>
    </div>

    <div class="form-group">
      <label>Versión</label>
      <input type="text" name="version" placeholder="1.0.0" maxlength="20">
    </div>

    <div class="form-group">
      <label>Tags (separados por comas)</label>
      <input type="text" name="tags" placeholder="Fox, HD, retexture, Slippi">
    </div>

    <!-- IMÁGENES: el input está FUERA del label para que multiple funcione en Windows -->
    <div class="form-group">
      <label for="img-input">Imágenes del mod (hasta 10) — la primera será la portada</label>
      <div class="upload-zone" id="img-zone" onclick="document.getElementById('img-input').click()" style="cursor:pointer">
        <div class="upload-icon">🖼️</div>
        <div class="upload-label" id="img-label">Haz clic aquí para seleccionar imágenes</div>
        <small>JPG, PNG, WEBP — puedes seleccionar varias a la vez</small>
      </div>
      <input type="file" id="img-input" name="images" multiple
             accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none"
             onchange="onImagesChange(this)">
      <div id="img-preview" style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px"></div>
    </div>

    <!-- .DAT: igual, input fuera del label -->
    <div class="form-group">
      <label for="dat-input">Archivos .dat del mod * — puedes seleccionar varios a la vez</label>
      <div class="upload-zone" id="dat-zone" onclick="document.getElementById('dat-input').click()" style="cursor:pointer">
        <div class="upload-icon">📦</div>
        <div class="upload-label" id="dat-label">Haz clic aquí para seleccionar archivos .dat</div>
        <small>Solo archivos .dat — máx. 200 MB cada uno</small>
      </div>
      <input type="file" id="dat-input" name="modfile" multiple accept=".dat"
             style="display:none" required onchange="onDatChange(this)">
      <div id="dat-list" style="margin-top:8px;display:flex;flex-direction:column;gap:4px"></div>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
      <button type="submit" class="btn btn-primary">Publicar mod</button>
      <a href="/" class="btn btn-ghost">Cancelar</a>
    </div>
  </form>
</div>

<script>
function onImagesChange(input) {
  var label   = document.getElementById('img-label');
  var preview = document.getElementById('img-preview');
  preview.innerHTML = '';
  if (!input.files || !input.files.length) return;
  label.textContent = input.files.length + ' imagen(es) seleccionada(s)';
  Array.from(input.files).forEach(function(f, i) {
    var wrap = document.createElement('div');
    wrap.style.cssText = 'position:relative;display:inline-block';
    var img = document.createElement('img');
    img.src = URL.createObjectURL(f);
    img.style.cssText = 'width:100px;height:67px;object-fit:cover;border-radius:6px;border:2px solid ' + (i===0?'var(--blue)':'var(--border)');
    wrap.appendChild(img);
    if (i === 0) {
      var badge = document.createElement('span');
      badge.textContent = 'Portada';
      badge.style.cssText = 'position:absolute;bottom:3px;left:3px;background:var(--blue);color:#fff;font-size:9px;padding:1px 5px;border-radius:3px;';
      wrap.appendChild(badge);
    }
    preview.appendChild(wrap);
  });
}

function onDatChange(input) {
  var label = document.getElementById('dat-label');
  var list  = document.getElementById('dat-list');
  list.innerHTML = '';
  if (!input.files || !input.files.length) return;
  label.textContent = input.files.length + ' archivo(s) .dat seleccionado(s)';
  Array.from(input.files).forEach(function(f) {
    var row = document.createElement('div');
    row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:7px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;font-size:0.85rem;';
    row.innerHTML = '<span>📄</span><span style="flex:1">' + f.name + '</span><span style="color:var(--muted)">' + (f.size/1024/1024).toFixed(2) + ' MB</span>';
    list.appendChild(row);
  });
}

// Drag & drop
document.getElementById('img-zone').addEventListener('dragover',  function(e){e.preventDefault();this.classList.add('drag-over');});
document.getElementById('img-zone').addEventListener('dragleave', function(){this.classList.remove('drag-over');});
document.getElementById('img-zone').addEventListener('drop', function(e){
  e.preventDefault(); this.classList.remove('drag-over');
  var inp = document.getElementById('img-input');
  inp.files = e.dataTransfer.files; onImagesChange(inp);
});
document.getElementById('dat-zone').addEventListener('dragover',  function(e){e.preventDefault();this.classList.add('drag-over');});
document.getElementById('dat-zone').addEventListener('dragleave', function(){this.classList.remove('drag-over');});
document.getElementById('dat-zone').addEventListener('drop', function(e){
  e.preventDefault(); this.classList.remove('drag-over');
  var inp = document.getElementById('dat-input');
  inp.files = e.dataTransfer.files; onDatChange(inp);
});
</script>
<%- include('../partials/footer') %>
